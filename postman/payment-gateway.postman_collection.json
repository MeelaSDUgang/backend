{
  "info": {
    "_postman_id": "4e1789b1-e53e-47aa-91c0-b4a35d6a1f06",
    "name": "Payment Gateway API",
    "description": "Local payment gateway requests with automatic HMAC headers. Import `payment-gateway.postman_environment.json`, select the environment, run `Get gateways` once to fill `bankId`, then call payment requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const apiKey = pm.environment.get('apiKey');",
          "const secretKey = pm.environment.get('secretKey');",
          "",
          "if (!apiKey || !secretKey) {",
          "  throw new Error('Set apiKey and secretKey in the selected Postman environment.');",
          "}",
          "",
          "function uuidv4() {",
          "  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function (c) {",
          "    const r = Math.random() * 16 | 0;",
          "    const v = c === 'x' ? r : (r & 0x3 | 0x8);",
          "    return v.toString(16);",
          "  });",
          "}",
          "",
          "const timestamp = Math.floor(Date.now() / 1000).toString();",
          "const rawBody = pm.request.body && pm.request.body.mode === 'raw'",
          "  ? pm.variables.replaceIn(pm.request.body.raw || '')",
          "  : '';",
          "const signature = CryptoJS.HmacSHA256(rawBody + timestamp, secretKey).toString(CryptoJS.enc.Hex).toLowerCase();",
          "",
          "pm.request.headers.upsert({ key: 'X-API-Key', value: apiKey });",
          "pm.request.headers.upsert({ key: 'X-Timestamp', value: timestamp });",
          "pm.request.headers.upsert({ key: 'X-Signature', value: signature });",
          "",
          "if (pm.request.method === 'POST') {",
          "  const idempotencyKey = uuidv4();",
          "  pm.environment.set('lastIdempotencyKey', idempotencyKey);",
          "  pm.request.headers.upsert({ key: 'Idempotency-Key', value: idempotencyKey });",
          "}",
          "",
          "pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Gateways",
      "item": [
        {
          "name": "Get gateways",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('gateway list returned', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const gateways = pm.response.json();",
                  "if (Array.isArray(gateways) && gateways.length > 0) {",
                  "  pm.environment.set('bankId', gateways[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayBaseUrl}}/api/v1/gateways",
              "host": [
                "{{gatewayBaseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "gateways"
              ]
            },
            "description": "Loads active bank adapters and stores the first gateway id into `bankId` environment variable."
          },
          "response": []
        }
      ]
    },
